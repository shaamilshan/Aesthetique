{
  "rewrites": [
    {
      "source": "/product/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(WhatsApp|facebookexternalhit|Twitterbot|Discordbot|Slackbot|LinkedInBot|Googlebot|bingbot).*"
        }
      ],
      "destination": "https://bm-aesthetique.vercel.app/api/public/share/product/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
